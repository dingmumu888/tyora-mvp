generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model SiteContent {
  id        String   @id @default("default")
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id                      String   @id
  customerName            String?
  company                 String?
  email                   String?
  country                 String?
  category                String?
  productIdea             String
  designType              String
  quantity                String
  budget                  String
  timeline                String
  sampleRequirement       String
  sampleReview            String?
  additionalRequirements  String
  uploadedFile            String?
  uploadedFilesJson       String   @default("[]")
  submissionDate          DateTime
  status                  String
  ownerId                 String?
  priority                String?
  lastContactDate         String?
  nextFollowUpDate        String?
  internalNotes           String?
  internalNoteEntriesJson String   @default("[]")
  statusHistoryJson       String   @default("[]")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([status])
  @@index([ownerId])
  @@index([priority])
  @@index([submissionDate])
}

model MediaAsset {
  id        String   @id
  name      String
  url       String
  type      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model TeamMember {
  id        String   @id
  name      String
  avatar    String
  email     String
  role      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([role])
}

model AnalyticsEvent {
  id                     String   @id
  type                   String
  path                   String?
  pageGroup              String?
  referrer               String?
  referrerSource         String?
  utmSource              String?
  utmMedium              String?
  utmCampaign            String?
  countryName            String?
  countryCode            String?
  cityName               String?
  device                 String?
  visitorId              String?
  ipHash                 String?
  maskedIp               String?
  sessionId              String?
  sessionDurationSeconds Int?
  createdAt              DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([visitorId])
  @@index([sessionId])
  @@index([countryCode])
  @@index([referrerSource])
  @@index([utmSource])
  @@index([ipHash])
  @@index([device])
}

model CommunityUser {
  id                     String              @id
  googleId               String?             @unique
  email                  String              @unique
  username               String              @unique
  name                   String
  avatar                 String?
  bio                    String?
  profileCompleted       Boolean             @default(false)
  country                String?
  lastNotificationSeenAt DateTime?
  lastLoginAt            DateTime?
  loginCount             Int                 @default(0)
  firstTrafficSource     String?
  lastCountry            String?
  lastCity               String?
  lastIpHash             String?
  lastMaskedIp           String?
  joinedAt               DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  ideas                  CommunityIdea[]
  comments               CommunityComment[]
  reactions              CommunityReaction[]

  @@index([joinedAt])
  @@index([country])
  @@index([lastLoginAt])
  @@index([firstTrafficSource])
}

model EmailLoginCode {
  id        String    @id
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
  @@index([createdAt])
}

model EmailVerificationThrottle {
  id              String    @id
  scope           String
  failureCount    Int       @default(0)
  windowStartedAt DateTime
  lockedUntil     DateTime?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([scope])
  @@index([lockedUntil])
  @@index([expiresAt])
}

model SourceRequest {
  id                 String   @id
  productName        String
  description        String
  productLink        String?
  material           String?
  quantity           String
  targetPrice        String?
  destinationCountry String
  email              String?
  whatsapp           String?
  needTypesJson      String   @default("[]")
  imageUrl           String?
  status             String   @default("New")
  internalNotes      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([destinationCountry])
}

model WorkOrderContactEvent {
  id             String    @id
  workOrderId    String
  channel        String
  note           String?
  contactedAt    DateTime
  nextFollowUpAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([workOrderId])
  @@index([contactedAt])
  @@index([nextFollowUpAt])
}

model CommunityIdea {
  id                    String              @id
  slug                  String              @unique
  title                 String
  description           String
  category              String
  country               String
  imageUrlsJson         String              @default("[]")
  questionsJson         String              @default("[]")
  otherQuestion         String?
  visibility            String              @default("Public")
  moderationStatus      String              @default("Pending")
  status                String              @default("Discussing")
  hidden                Boolean             @default(false)
  locked                Boolean             @default(false)
  pinned                Boolean             @default(false)
  homepageFeatured      Boolean             @default(false)
  homepageFeaturedOrder Int?
  authorId              String
  author                CommunityUser       @relation(fields: [authorId], references: [id])
  comments              CommunityComment[]
  review                TyoraReview?
  reactions             CommunityReaction[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([visibility])
  @@index([moderationStatus])
  @@index([hidden])
  @@index([pinned])
  @@index([homepageFeatured, homepageFeaturedOrder])
  @@index([createdAt])
  @@index([updatedAt])
}

model CommunityComment {
  id        String              @id
  body      String
  hidden    Boolean             @default(false)
  ideaId    String
  idea      CommunityIdea       @relation(fields: [ideaId], references: [id])
  authorId  String
  author    CommunityUser       @relation(fields: [authorId], references: [id])
  parentId  String?
  reactions CommunityReaction[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([ideaId])
  @@index([authorId])
  @@index([parentId])
  @@index([hidden])
  @@index([createdAt])
}

model TyoraReview {
  id                     String        @id
  ideaId                 String        @unique
  idea                   CommunityIdea @relation(fields: [ideaId], references: [id])
  manufacturingFeasible  String?
  estimatedCostRange     String?
  suggestedMaterial      String?
  estimatedMoq           String?
  suggestedManufacturing String?
  factoriesMatched       String?
  additionalNotes        String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([createdAt])
}

model CommunityReaction {
  id        String            @id
  type      String
  userId    String
  user      CommunityUser     @relation(fields: [userId], references: [id])
  ideaId    String?
  idea      CommunityIdea?    @relation(fields: [ideaId], references: [id])
  commentId String?
  comment   CommunityComment? @relation(fields: [commentId], references: [id])
  createdAt DateTime          @default(now())

  @@unique([userId, type, ideaId])
  @@unique([userId, type, commentId])
  @@index([type])
  @@index([ideaId])
  @@index([commentId])
  @@index([createdAt])
}
