generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum SubmissionRecordKind {
  COMMUNITY_IDEA
  CUSTOM_INQUIRY
  SOURCE_REQUEST
  LEAD
}

enum SubmissionType {
  IDEA
  CUSTOM
  SOURCE
  PROJECT
}

enum WorkflowQualification {
  UNREVIEWED
  QUALIFIED
  NEED_MORE_INFORMATION
  OUT_OF_SCOPE
  LOW_BUDGET
  HIGH_RISK
  SPAM
}

enum SubmissionWorkflowStatus {
  NEW
  UNDER_REVIEW
  REVIEW_SENT
  QUALIFIED
  KICKOFF_PENDING
  FACTORY_SOURCING
  QUOTING
  SAMPLING
  PRODUCTION
  QUALITY_INSPECTION
  DELIVERED
  REORDER
  CLOSED
  LOST
}

enum WorkflowServiceModel {
  FREE_ASSESSMENT
  SOURCE_INTRODUCTION
  SOURCE_MANAGED
  CUSTOM_INTRODUCTION
  CUSTOM_MANAGED
  REORDER_MANAGED
  INSPECTION_ONLY
}

enum WorkflowPaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  PARTIALLY_PAID
  REFUNDED
  CANCELLED
}

enum WorkflowPrivacyState {
  PUBLIC
  PRIVATE
}

enum ModerationVisibilityAction {
  APPROVE
  HIDE
  UNHIDE
  ARCHIVE
  RESTORE
  MARK_SPAM
  FEATURE
  UNFEATURE
  SET_PUBLIC
  SET_PRIVATE
  CONFIRM_PRIVATE_TO_PUBLIC
}

model SiteContent {
  id        String   @id @default("default")
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id                      String   @id
  customerName            String?
  company                 String?
  email                   String?
  country                 String?
  category                String?
  productIdea             String
  designType              String
  quantity                String
  budget                  String
  timeline                String
  sampleRequirement       String
  sampleReview            String?
  additionalRequirements  String
  uploadedFile            String?
  uploadedFilesJson       String   @default("[]")
  submissionDate          DateTime
  status                  String
  ownerId                 String?
  priority                String?
  lastContactDate         String?
  nextFollowUpDate        String?
  internalNotes           String?
  internalNoteEntriesJson String   @default("[]")
  statusHistoryJson       String   @default("[]")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([status])
  @@index([ownerId])
  @@index([priority])
  @@index([submissionDate])
}

model MediaAsset {
  id        String   @id
  name      String
  url       String
  type      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model TeamMember {
  id                              String                           @id
  name                            String
  avatar                          String
  email                           String
  role                            String
  active                          Boolean                          @default(true)
  assignedSubmissionWorkflows     SubmissionWorkflow[]             @relation("WorkflowAssignedOwner")
  workflowStatusEvents            WorkflowStatusEvent[]            @relation("WorkflowStatusActor")
  moderationVisibilityAuditEvents ModerationVisibilityAuditEvent[] @relation("ModerationVisibilityActor")
  createdAt                       DateTime                         @default(now())
  updatedAt                       DateTime                         @updatedAt

  @@index([active])
  @@index([role])
}

model AnalyticsEvent {
  id                     String   @id
  type                   String
  path                   String?
  pageGroup              String?
  referrer               String?
  referrerSource         String?
  utmSource              String?
  utmMedium              String?
  utmCampaign            String?
  countryName            String?
  countryCode            String?
  cityName               String?
  device                 String?
  visitorId              String?
  ipHash                 String?
  maskedIp               String?
  sessionId              String?
  sessionDurationSeconds Int?
  createdAt              DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([visitorId])
  @@index([sessionId])
  @@index([countryCode])
  @@index([referrerSource])
  @@index([utmSource])
  @@index([ipHash])
  @@index([device])
}

model CommunityUser {
  id                     String              @id
  googleId               String?             @unique
  email                  String              @unique
  username               String              @unique
  name                   String
  avatar                 String?
  bio                    String?
  profileCompleted       Boolean             @default(false)
  country                String?
  lastNotificationSeenAt DateTime?
  lastLoginAt            DateTime?
  loginCount             Int                 @default(0)
  firstTrafficSource     String?
  lastCountry            String?
  lastCity               String?
  lastIpHash             String?
  lastMaskedIp           String?
  joinedAt               DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  ideas                  CommunityIdea[]
  comments               CommunityComment[]
  reactions              CommunityReaction[]
  customInquiries        CustomInquiry[]
  shares                 CommunityShare[]

  @@index([joinedAt])
  @@index([country])
  @@index([lastLoginAt])
  @@index([firstTrafficSource])
}

model EmailLoginCode {
  id        String    @id
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
  @@index([createdAt])
}

model EmailVerificationThrottle {
  id              String    @id
  scope           String
  failureCount    Int       @default(0)
  windowStartedAt DateTime
  lockedUntil     DateTime?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([scope])
  @@index([lockedUntil])
  @@index([expiresAt])
}

model SourceRequest {
  id                 String   @id
  productName        String
  description        String
  productLink        String?
  material           String?
  quantity           String
  targetPrice        String?
  destinationCountry String
  email              String?
  whatsapp           String?
  needTypesJson      String   @default("[]")
  imageUrl           String?
  status             String   @default("New")
  internalNotes      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([destinationCountry])
}

model WorkOrderContactEvent {
  id             String    @id
  workOrderId    String
  channel        String
  note           String?
  contactedAt    DateTime
  nextFollowUpAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([workOrderId])
  @@index([contactedAt])
  @@index([nextFollowUpAt])
}

model SubmissionWorkflow {
  id                         String                           @id
  recordKind                 SubmissionRecordKind
  sourceId                   String
  submissionType             SubmissionType
  qualification              WorkflowQualification            @default(UNREVIEWED)
  workflowStatus             SubmissionWorkflowStatus         @default(NEW)
  assignedOwnerId            String?
  assignedOwner              TeamMember?                      @relation("WorkflowAssignedOwner", fields: [assignedOwnerId], references: [id], onDelete: SetNull)
  nextFollowUpAt             DateTime?
  lastContactAt              DateTime?
  productCategoryFit         String?
  budgetFit                  String?
  designReadiness            String?
  targetQuantity             String?
  targetMarket               String?
  salesChannel               String?
  complianceRisk             String?
  manufacturingComplexity    String?
  internalSummary            String?
  recommendedNextStep        String?
  serviceModel               WorkflowServiceModel?
  paymentStatus              WorkflowPaymentStatus            @default(NOT_REQUIRED)
  estimatedOrderValueMinor   BigInt?
  feePercentageBasisPoints   Int?
  minimumFeeMinor            BigInt?
  finalAgreedServiceFeeMinor BigInt?
  kickoffFeeMinor            BigInt?
  currencyCode               String?                          @db.VarChar(3)
  customerSnapshotJson       String                           @default("{}")
  privacyState               WorkflowPrivacyState
  legacyStatus               String?
  manualReviewRequired       Boolean                          @default(false)
  manualReviewReason         String?
  submittedAt                DateTime
  statusEvents               WorkflowStatusEvent[]
  moderationVisibilityEvents ModerationVisibilityAuditEvent[]
  createdAt                  DateTime                         @default(now())
  updatedAt                  DateTime                         @updatedAt

  @@unique([recordKind, sourceId])
  @@index([submissionType])
  @@index([qualification])
  @@index([workflowStatus])
  @@index([assignedOwnerId])
  @@index([nextFollowUpAt])
  @@index([privacyState])
  @@index([submittedAt])
}

model WorkflowStatusEvent {
  id                      String                    @id
  workflowId              String
  workflow                SubmissionWorkflow        @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  previousStatus          SubmissionWorkflowStatus?
  newStatus               SubmissionWorkflowStatus
  actorId                 String?
  actor                   TeamMember?               @relation("WorkflowStatusActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorIdentifierSnapshot String
  actorLabelSnapshot      String
  note                    String?
  createdAt               DateTime                  @default(now())

  @@index([workflowId, createdAt])
  @@index([actorId])
  @@index([newStatus])
}

model ModerationVisibilityAuditEvent {
  id                       String                     @id
  workflowId               String
  workflow                 SubmissionWorkflow         @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  action                   ModerationVisibilityAction
  previousModerationStatus String?
  newModerationStatus      String?
  previousPrivacyState     WorkflowPrivacyState?
  newPrivacyState          WorkflowPrivacyState?
  privateToPublicConfirmed Boolean                    @default(false)
  actorId                  String?
  actor                    TeamMember?                @relation("ModerationVisibilityActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorIdentifierSnapshot  String
  actorLabelSnapshot       String
  note                     String?
  createdAt                DateTime                   @default(now())

  @@index([workflowId, createdAt])
  @@index([actorId])
  @@index([action])
}

model CommunityIdea {
  id                    String              @id
  slug                  String              @unique
  title                 String
  description           String
  category              String
  country               String
  imageUrlsJson         String              @default("[]")
  questionsJson         String              @default("[]")
  otherQuestion         String?
  visibility            String              @default("Public")
  moderationStatus      String              @default("Pending")
  status                String              @default("Discussing")
  hidden                Boolean             @default(false)
  locked                Boolean             @default(false)
  pinned                Boolean             @default(false)
  homepageFeatured      Boolean             @default(false)
  homepageFeaturedOrder Int?
  publicConsentAt       DateTime?
  moderatedAt           DateTime?
  moderationNote        String?
  authorId              String
  author                CommunityUser       @relation(fields: [authorId], references: [id])
  comments              CommunityComment[]
  review                TyoraReview?
  reactions             CommunityReaction[]
  shares                CommunityShare[]
  customInquiries       CustomInquiry[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([visibility])
  @@index([moderationStatus])
  @@index([hidden])
  @@index([pinned])
  @@index([homepageFeatured, homepageFeaturedOrder])
  @@index([createdAt])
  @@index([updatedAt])
}

model CommunityComment {
  id        String              @id
  body      String
  hidden    Boolean             @default(false)
  ideaId    String
  idea      CommunityIdea       @relation(fields: [ideaId], references: [id])
  authorId  String
  author    CommunityUser       @relation(fields: [authorId], references: [id])
  parentId  String?
  reactions CommunityReaction[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([ideaId])
  @@index([authorId])
  @@index([parentId])
  @@index([hidden])
  @@index([createdAt])
}

model TyoraReview {
  id                     String        @id
  ideaId                 String        @unique
  idea                   CommunityIdea @relation(fields: [ideaId], references: [id])
  manufacturingFeasible  String?
  estimatedCostRange     String?
  suggestedMaterial      String?
  estimatedMoq           String?
  suggestedManufacturing String?
  factoriesMatched       String?
  additionalNotes        String?
  moldRequirement        String?
  assumptions            String?
  confidence             String?
  assessmentStatus       String        @default("Draft")
  disclaimer             String
  mainRisks              String?
  recommendedNextStep    String?
  customEligible         Boolean       @default(false)
  publishedAt            DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([createdAt])
}

model CustomInquiry {
  id                     String         @id
  userId                 String
  user                   CommunityUser  @relation(fields: [userId], references: [id])
  ideaId                 String?
  idea                   CommunityIdea? @relation(fields: [ideaId], references: [id])
  productName            String
  productDescription     String
  category               String
  quantity               String
  budget                 String
  targetMarket           String
  timeline               String
  contactEmail           String?
  contactWhatsapp        String?
  privateFilesJson       String         @default("[]")
  ideaSnapshotJson       String         @default("{}")
  assessmentSnapshotJson String         @default("{}")
  status                 String         @default("Submitted")
  nextStep               String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([userId])
  @@index([ideaId])
  @@index([status])
  @@index([createdAt])
}

model CommunityShare {
  id        String        @id
  channel   String
  userId    String
  user      CommunityUser @relation(fields: [userId], references: [id])
  ideaId    String
  idea      CommunityIdea @relation(fields: [ideaId], references: [id])
  createdAt DateTime      @default(now())

  @@unique([userId, ideaId, channel])
  @@index([ideaId])
  @@index([createdAt])
}

model CommunityActionThrottle {
  id              String   @id
  scope           String
  count           Int      @default(0)
  windowStartedAt DateTime
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([scope])
  @@index([expiresAt])
}

model CommunityActionReceipt {
  id         String   @id
  userId     String
  action     String
  resourceId String
  resultJson String   @default("{}")
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([resourceId])
  @@index([expiresAt])
}

model CommunityReaction {
  id        String            @id
  type      String
  userId    String
  user      CommunityUser     @relation(fields: [userId], references: [id])
  ideaId    String?
  idea      CommunityIdea?    @relation(fields: [ideaId], references: [id])
  commentId String?
  comment   CommunityComment? @relation(fields: [commentId], references: [id])
  createdAt DateTime          @default(now())

  @@unique([userId, type, ideaId])
  @@unique([userId, type, commentId])
  @@index([type])
  @@index([ideaId])
  @@index([commentId])
  @@index([createdAt])
}
